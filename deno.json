{
  "name": "@bounded-systems/trellis",
  "version": "0.1.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "exports": {
    ".": "./schema.ts",
    "./registry": "./registry.ts",
    "./assemble": "./assemble.ts",
    "./verbs": "./verbs.ts",
    "./status": "./status.ts"
  },
  "imports": {
    "zod": "npm:zod@^4.4.3",
    "verbspec": "jsr:@bounded-systems/verbspec@^0.3.1",
    "@bounded-systems/trellis-kit": "jsr:@bounded-systems/trellis-kit@^0.1.0",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check schema.ts registry.ts assemble.ts verbs.ts gen.ts status.ts specs/scoutd.ts check/parse.ts check/keeper-wire.ts check/scout-wire.ts check/lattice.ts",
    "test": "deno test --allow-read",
    "gen": "deno run --allow-read --allow-write gen.ts",
    "status": "deno run --allow-read status.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "verbs": "deno run --allow-read verbs.ts"
  },
  "fmt": {
    "include": ["*.ts", "specs/*.ts", "check/*.ts"],
    "exclude": [".fixtures"]
  },
  "lint": {
    "include": ["*.ts", "specs/*.ts", "check/*.ts"],
    "exclude": [".fixtures"]
  },
  "publish": {
    "include": [
      "schema.ts",
      "registry.ts",
      "assemble.ts",
      "verbs.ts",
      "gen.ts",
      "status.ts",
      "deno.lock",
      "specs/scoutd.ts",
      "specs/scout-wire.json",
      "check/parse.ts",
      "check/keeper-wire.ts",
      "check/scout-wire.ts",
      "check/lattice.ts",
      "bootstrap",
      "LICENSE",
      "README.md"
    ]
  }
}
